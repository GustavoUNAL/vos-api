// vos.ai — Multi-tenant platform schema (v2 foundation)
// Deploy target: fresh PostgreSQL (Neon). Legacy single-tenant schema lives in schema.legacy.prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum MemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProductCostSource {
  MANUAL
  RECIPE
}

enum RecipeCostKind {
  FIJO
  VARIABLE
}

enum InventoryBehavior {
  CONSUMABLE
  CAPITAL_ASSET
}

enum SaleSource {
  MANUAL
  POS
  IMPORT
}

enum StaffShiftStatus {
  OPEN
  CLOSED
  PAID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
}

enum AiMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

// ---------------------------------------------------------------------------
// Platform — Tenancy & identity
// ---------------------------------------------------------------------------

model Company {
  id        String        @id @default(cuid())
  name      String
  taxId     String?       @map("tax_id")
  address   String?
  phone     String?
  email     String?
  status    CompanyStatus @default(ACTIVE)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  members          CompanyMember[]
  roles            Role[]
  companyModules   CompanyModule[]
  productCategories ProductCategory[]
  products         Product[]
  productImages    ProductImage[]
  aiAgents         AiAgent[]
  aiConversations  AiConversation[]
  aiMessages       AiMessage[]
  auditLogs        AuditLog[]
  inventoryItems   InventoryItem[]
  recipes          Recipe[]
  sales            Sale[]
  purchaseLots     PurchaseLot[]
  purchaseLotLines PurchaseLotLine[]
  staffMembers     StaffMember[]
  staffShifts      StaffShift[]

  @@index([status], map: "idx_companies_status")
  @@index([name], map: "idx_companies_name")
  @@map("companies")
}

/// Global identity (one email = one login across companies).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships     CompanyMember[]
  aiConversations AiConversation[]
  auditLogs       AuditLog[]
  salesRecorded   Sale[]           @relation("SaleRecordedBy")

  @@index([active], map: "idx_users_active")
  @@map("users")
}

/// Membership: user ↔ company (many-to-many).
model CompanyMember {
  id        String       @id @default(cuid())
  companyId String       @map("company_id")
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String       @map("user_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    MemberStatus @default(ACTIVE)
  joinedAt  DateTime     @default(now()) @map("joined_at") @db.Timestamptz(6)

  memberRoles CompanyMemberRole[]

  @@unique([companyId, userId], map: "company_members_company_user_key")
  @@index([companyId], map: "idx_company_members_company_id")
  @@index([userId], map: "idx_company_members_user_id")
  @@index([status], map: "idx_company_members_status")
  @@map("company_members")
}

// ---------------------------------------------------------------------------
// RBAC — Roles & permissions (scoped per company or system-wide)
// ---------------------------------------------------------------------------

model Role {
  id          String  @id @default(cuid())
  companyId   String? @map("company_id")
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slug        String
  name        String
  description String?
  isSystem    Boolean @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rolePermissions RolePermission[]
  memberRoles     CompanyMemberRole[]

  @@unique([companyId, slug], map: "roles_company_slug_key")
  @@index([companyId], map: "idx_roles_company_id")
  @@map("roles")
}

model Permission {
  id          String @id @default(cuid())
  slug        String @unique
  moduleSlug  String @map("module_slug")
  name        String
  description String?

  rolePermissions RolePermission[]

  @@index([moduleSlug], map: "idx_permissions_module_slug")
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  role         Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model CompanyMemberRole {
  companyMemberId String        @map("company_member_id")
  companyMember   CompanyMember @relation(fields: [companyMemberId], references: [id], onDelete: Cascade)
  roleId          String        @map("role_id")
  role            Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([companyMemberId, roleId])
  @@map("company_member_roles")
}

// ---------------------------------------------------------------------------
// Modules — Feature flags per company
// ---------------------------------------------------------------------------

model Module {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  companyModules CompanyModule[]

  @@map("modules")
}

model CompanyModule {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  moduleId  String   @map("module_id")
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  isEnabled Boolean  @default(true) @map("is_enabled")
  enabledAt DateTime @default(now()) @map("enabled_at") @db.Timestamptz(6)

  @@unique([companyId, moduleId], map: "company_modules_company_module_key")
  @@index([companyId], map: "idx_company_modules_company_id")
  @@index([isEnabled], map: "idx_company_modules_is_enabled")
  @@map("company_modules")
}

// ---------------------------------------------------------------------------
// Products module (multi-tenant)
// ---------------------------------------------------------------------------

model ProductCategory {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  parentId  String?  @map("parent_id")
  parent    ProductCategory? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProductCategory[] @relation("CategoryTree")
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  products         Product[]
  inventoryItems InventoryItem[]
  purchaseLotLines PurchaseLotLine[]

  @@unique([companyId, slug], map: "product_categories_company_slug_key")
  @@index([companyId], map: "idx_product_categories_company_id")
  @@index([parentId], map: "idx_product_categories_parent_id")
  @@map("product_categories")
}

model Product {
  id              String        @id @default(cuid())
  companyId       String        @map("company_id")
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId      String        @map("category_id")
  category        ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name            String
  description     String        @default("")
  sku             String?
  internalCode    String?       @map("internal_code")
  salePrice       Decimal       @map("sale_price") @db.Decimal(14, 2)
  cost            Decimal       @default(0) @db.Decimal(14, 2)
  costSource      ProductCostSource @default(MANUAL) @map("cost_source")
  /// Read-only: PostgreSQL GENERATED STORED column (see vos-platform-init.sql).
  marginPercent   Decimal?      @map("margin_percent") @db.Decimal(8, 4) @default(dbgenerated())
  status          ProductStatus @default(DRAFT)
  primaryImageUrl String?       @map("primary_image_url")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  images ProductImage[]
  recipe Recipe?
  saleLines SaleLine[]

  @@unique([companyId, sku], map: "products_company_sku_key")
  @@unique([companyId, internalCode], map: "products_company_internal_code_key")
  @@index([companyId], map: "idx_products_company_id")
  @@index([categoryId], map: "idx_products_category_id")
  @@index([status], map: "idx_products_status")
  @@index([companyId, status], map: "idx_products_company_status")
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String? @map("alt_text")
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([companyId], map: "idx_product_images_company_id")
  @@index([productId], map: "idx_product_images_product_id")
  @@index([productId, isPrimary], map: "idx_product_images_product_primary")
  @@map("product_images")
}

// ---------------------------------------------------------------------------
// Inventory & recipes (multi-tenant)
// ---------------------------------------------------------------------------

model InventoryItem {
  id         String            @id @default(cuid())
  companyId  String            @map("company_id")
  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId String?           @map("category_id")
  category   ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name       String
  unit       String            @default("und")
  unitCost   Decimal           @default(0) @map("unit_cost") @db.Decimal(14, 2)
  quantity   Decimal           @default(0) @db.Decimal(14, 4)
  minStock   Decimal?          @map("min_stock") @db.Decimal(14, 4)
  lotLabel   String?           @map("lot_label")
  behavior   InventoryBehavior @default(CONSUMABLE)
  active     Boolean           @default(true)
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  recipeIngredients RecipeIngredient[]
  purchaseLotId     String?           @map("purchase_lot_id")
  purchaseLot       PurchaseLot?      @relation(fields: [purchaseLotId], references: [id], onDelete: SetNull)
  purchaseLotLine   PurchaseLotLine?

  @@index([companyId], map: "idx_inventory_items_company_id")
  @@index([categoryId], map: "idx_inventory_items_category_id")
  @@index([companyId, active], map: "idx_inventory_items_company_active")
  @@map("inventory_items")
}

/// Una receta por producto (`product_id` único).
model Recipe {
  id          String  @id @default(cuid())
  companyId   String  @map("company_id")
  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId   String  @unique @map("product_id")
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipeYield Decimal @default(1) @map("yield") @db.Decimal(12, 4)
  adminRate   Decimal @default(0.30) @map("admin_rate") @db.Decimal(5, 4)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  ingredients RecipeIngredient[]
  costs       RecipeCost[]

  @@index([companyId], map: "idx_recipes_company_id")
  @@index([productId], map: "idx_recipes_product_id")
  @@map("recipes")
}

model RecipeCost {
  id            String         @id @default(cuid())
  recipeId      String         @map("recipe_id")
  recipe        Recipe         @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  kind          RecipeCostKind
  name          String
  quantity      Decimal?       @db.Decimal(12, 4)
  unit          String
  lineTotalCOP  Decimal        @map("line_total_cop") @db.Decimal(12, 2)
  sheetUnitCost String?        @map("sheet_unit_cost")
  sortOrder     Int            @default(0) @map("sort_order")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([recipeId], map: "idx_recipe_costs_recipe_id")
  @@map("recipe_costs")
}

model RecipeIngredient {
  id              String        @id @default(cuid())
  recipeId        String        @map("recipe_id")
  recipe          Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItemId String        @map("inventory_item_id")
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  quantity        Decimal       @db.Decimal(12, 4)
  unit            String
  sortOrder       Int           @default(0) @map("sort_order")

  @@index([recipeId], map: "idx_recipe_ingredients_recipe_id")
  @@index([inventoryItemId], map: "idx_recipe_ingredients_inventory_item_id")
  @@map("recipe_ingredients")
}

// ---------------------------------------------------------------------------
// Sales & purchases (multi-tenant)
// ---------------------------------------------------------------------------

model Sale {
  id            String     @id @default(cuid())
  companyId     String     @map("company_id")
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code          String?
  saleDate      DateTime   @map("sale_date") @db.Timestamptz(6)
  total         Decimal    @db.Decimal(14, 2)
  paymentMethod String?    @map("payment_method")
  source        SaleSource @default(MANUAL)
  userId        String?    @map("user_id")
  user          User?      @relation("SaleRecordedBy", fields: [userId], references: [id], onDelete: SetNull)
  mesa          String?
  notes         String?
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  lines SaleLine[]

  @@unique([companyId, code], map: "sales_company_code_key")
  @@index([companyId], map: "idx_sales_company_id")
  @@index([companyId, saleDate], map: "idx_sales_company_sale_date")
  @@index([saleDate], map: "idx_sales_sale_date")
  @@map("sales")
}

model SaleLine {
  id          String   @id @default(cuid())
  saleId      String   @map("sale_id")
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String?  @map("product_id")
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String   @map("product_name")
  lineUnit    String?  @map("line_unit")
  lineSize    String?  @map("line_size")
  quantity    Decimal  @db.Decimal(12, 4)
  unitPrice   Decimal  @map("unit_price") @db.Decimal(14, 2)
  costAtSale  Decimal? @map("cost_at_sale") @db.Decimal(14, 2)
  profit      Decimal? @db.Decimal(14, 2)

  @@index([saleId], map: "idx_sale_lines_sale_id")
  @@index([productId], map: "idx_sale_lines_product_id")
  @@map("sale_lines")
}

model PurchaseLot {
  id           String   @id @default(cuid())
  companyId    String   @map("company_id")
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code         String
  name         String?
  purchaseDate DateTime @map("purchase_date") @db.Timestamptz(6)
  supplier     String?
  notes        String?
  itemCount    Int      @default(0) @map("item_count")
  totalValue   Decimal? @map("total_value") @db.Decimal(14, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  lines            PurchaseLotLine[]
  inventoryItems   InventoryItem[]

  @@unique([companyId, code], map: "purchase_lots_company_code_key")
  @@index([companyId], map: "idx_purchase_lots_company_id")
  @@index([companyId, purchaseDate], map: "idx_purchase_lots_company_purchase_date")
  @@index([purchaseDate], map: "idx_purchase_lots_purchase_date")
  @@map("purchase_lots")
}

model PurchaseLotLine {
  id                  String           @id @default(cuid())
  companyId           String           @map("company_id")
  company             Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseLotId       String           @map("purchase_lot_id")
  purchaseLot         PurchaseLot      @relation(fields: [purchaseLotId], references: [id], onDelete: Cascade)
  inventoryItemId     String?          @unique @map("inventory_item_id")
  inventoryItem       InventoryItem?   @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  categoryId          String?          @map("category_id")
  category            ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  lineName            String           @map("line_name")
  quantityPurchased   Decimal          @map("quantity_purchased") @db.Decimal(12, 4)
  unit                String
  purchaseUnitCostCOP Decimal          @map("purchase_unit_cost_cop") @db.Decimal(14, 2)
  lineTotalCOP        Decimal          @map("line_total_cop") @db.Decimal(14, 2)
  lineComment         String?          @map("line_comment")
  sortOrder           Int              @default(0) @map("sort_order")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([purchaseLotId], map: "idx_purchase_lot_lines_lot_id")
  @@index([companyId], map: "idx_purchase_lot_lines_company_id")
  @@map("purchase_lot_lines")
}

// ---------------------------------------------------------------------------
// AI — Agents, conversations, messages (future-ready)
// ---------------------------------------------------------------------------

model AiAgent {
  id           String  @id @default(cuid())
  companyId    String  @map("company_id")
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  systemPrompt String? @map("system_prompt")
  model        String  @default("gpt-4o-mini")
  active       Boolean @default(true)
  config       Json?   @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  conversations AiConversation[]

  @@unique([companyId, slug], map: "ai_agents_company_slug_key")
  @@index([companyId], map: "idx_ai_agents_company_id")
  @@map("ai_agents")
}

model AiConversation {
  id        String   @id @default(cuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentId   String?  @map("agent_id")
  agent     AiAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title     String?
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  messages AiMessage[]

  @@index([companyId], map: "idx_ai_conversations_company_id")
  @@index([agentId], map: "idx_ai_conversations_agent_id")
  @@index([userId], map: "idx_ai_conversations_user_id")
  @@map("ai_conversations")
}

model AiMessage {
  id             String        @id @default(cuid())
  companyId      String        @map("company_id")
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversationId String        @map("conversation_id")
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AiMessageRole
  content        String
  tokenCount     Int?          @map("token_count")
  metadata       Json?         @db.JsonB
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([companyId], map: "idx_ai_messages_company_id")
  @@index([conversationId], map: "idx_ai_messages_conversation_id")
  @@index([createdAt], map: "idx_ai_messages_created_at")
  @@map("ai_messages")
}

// ---------------------------------------------------------------------------
// Personal — turnos y tarifa por hora
// ---------------------------------------------------------------------------

model StaffMember {
  id                 String   @id @default(cuid())
  companyId          String   @map("company_id")
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  phone              String?
  email              String?
  idNumber           String?  @map("id_number")
  defaultHourlyRate  Decimal  @default(0) @map("default_hourly_rate") @db.Decimal(14, 2)
  active             Boolean  @default(true)
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  shifts StaffShift[]

  @@index([companyId], map: "idx_staff_members_company_id")
  @@index([companyId, active], map: "idx_staff_members_company_active")
  @@map("staff_members")
}

model StaffShift {
  id             String           @id @default(cuid())
  companyId      String           @map("company_id")
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  staffMemberId  String           @map("staff_member_id")
  staffMember    StaffMember      @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  shiftDate      DateTime         @map("shift_date") @db.Date
  startAt        DateTime         @map("start_at") @db.Timestamptz(6)
  endAt          DateTime?        @map("end_at") @db.Timestamptz(6)
  hourlyRateCOP  Decimal          @map("hourly_rate_cop") @db.Decimal(14, 2)
  hoursWorked    Decimal?         @map("hours_worked") @db.Decimal(8, 4)
  totalPayCOP    Decimal?         @map("total_pay_cop") @db.Decimal(14, 2)
  status         StaffShiftStatus @default(OPEN)
  notes          String?
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([companyId], map: "idx_staff_shifts_company_id")
  @@index([staffMemberId], map: "idx_staff_shifts_staff_member_id")
  @@index([companyId, shiftDate], map: "idx_staff_shifts_company_shift_date")
  @@index([shiftDate], map: "idx_staff_shifts_shift_date")
  @@map("staff_shifts")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

model AuditLog {
  id         String      @id @default(cuid())
  companyId  String?     @map("company_id")
  company    Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId     String?     @map("user_id")
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  tableName  String      @map("table_name")
  recordId   String?     @map("record_id")
  oldValues  Json?       @map("old_values") @db.JsonB
  newValues  Json?       @map("new_values") @db.JsonB
  ipAddress  String?     @map("ip_address")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([companyId], map: "idx_audit_logs_company_id")
  @@index([userId], map: "idx_audit_logs_user_id")
  @@index([tableName], map: "idx_audit_logs_table_name")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([companyId, createdAt], map: "idx_audit_logs_company_created")
  @@map("audit_logs")
}
