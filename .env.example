# Copiar a .env — no commitear.

# --- Neon (producción / desarrollo) ---
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Primera vez contra Neon vacío:
#   npm run db:migrate
#   npm run db:seed-platform

# --- Local Docker (opcional) ---
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/vos"

# Auth (producción: openssl rand -base64 48)
JWT_SECRET=dev-secret-change-me-min-32-chars-required
JWT_EXPIRES_IN=7d

PORT=3000

# WhatsApp Cloud API (Meta) — comprobantes de venta al cliente
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Tienda pública (#/tienda)
# SHOP_NEQUI_PHONE=3001234567
# SHOP_BREB_KEY=@ARANDANOCAFE
# SHOP_FRONT_URL=http://localhost:5173
# WOMPI_PRIVATE_KEY=
# WOMPI_API_BASE=https://production.wompi.co/v1

# Neon: usar URL directa (sin -pooler) para migraciones si falla P1002 advisory lock
# DIRECT_DATABASE_URL=postgresql://...@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# LISTEN_HOST=0.0.0.0

# Producción — obligatorio si NODE_ENV=production
# CORS_ORIGIN=http://TU_IP:8080,https://app.tudominio.com

# Docker VPS (docker-compose.vps.yml)
# VITE_API_URL=http://TU_IP:3000
# API_SERVER_PORT=3000
# FRONT_SERVER_PORT=8080
# FRONTEND_BUILD_CONTEXT=../vos.ai-front
# RUN_MIGRATIONS_ON_START=true
# VITE_PLATFORM_MODE=true
