# Copiar a .env y ajustar.

# PostgreSQL local (coincide con docker-compose.yml por defecto)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/arandano"

JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# Producción: NODE_ENV=production y JWT_SECRET largo y aleatorio
# NODE_ENV=production

PORT=3000

# Opcional: interfaz de escucha (por defecto 0.0.0.0 = todas; útil detrás de Docker/nginx).
# LISTEN_HOST=127.0.0.1

# Primera subida con Docker de una sola réplica (opcional):
# RUN_MIGRATIONS_ON_START=true

# Opcional: Postgres remoto (Railway, etc.) para npm run db:pg-copy-database
# PG_COPY_DIRECTION=pull   # remoto → DATABASE_URL   |   push = local → remoto
# REMOTE_DATABASE_URL="postgresql://..."

# En producción, dominio(s) del front separados por coma:
# CORS_ORIGIN=https://app.tudominio.com
# En local, sin variable se permiten 5173, 4173, 3000 (Vite / preview).

# --- Stack Docker (docker compose --profile full) ---
# FRONTEND_BUILD_CONTEXT=../ruta-a-tu-vite-app
# FRONTEND_DOCKERFILE=Dockerfile
# VITE_API_URL=http://localhost:3000
# API_STACK_PORT=3000
# FRONT_STACK_PORT=8080
# CORS_STACK=http://localhost:8080,http://127.0.0.1:8080
