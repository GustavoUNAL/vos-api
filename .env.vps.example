# =============================================================================
# VOS API — VPS Arándano (PM2)
# =============================================================================
# Copiar en el servidor:
#   cp .env.vps.example .env
#   nano .env   # completar DATABASE_URL, JWT_SECRET, OPENAI_API_KEY
#
# ⚠️ En el VPS NO dejes .env.local (pisa CORS y PORT). Solo este .env
#
# Puerto 3001: el 3000 ya lo usa la app Next.js "arandano" en este servidor.
# =============================================================================

# --- Base de datos (Neon) ---
DATABASE_URL="postgresql://USER:PASS@ep-xxx.neon.tech/neondb?sslmode=require"

# --- Auth (openssl rand -base64 48) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

NODE_ENV=production
PORT=3001
LISTEN_HOST=0.0.0.0

# Orígenes del front — EXACTOS (protocolo + host + puerto, sin / final).
# Incluí IP (pruebas) y dominio (producción).
CORS_ORIGIN=http://51.222.24.228:5174,https://vos-ai.arandano.shop,http://vos-ai.arandano.shop

HTTP_BODY_LIMIT=12mb

# Asistente IA + bot landing
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_ENABLED=false

# --- Solo si usás Docker en este VPS (no PM2) ---
# RUN_MIGRATIONS_ON_START=true
# VITE_API_URL=https://vos-ai.arandano.shop/backend
# VITE_APP_URL=https://vos-ai.arandano.shop
# FRONTEND_BUILD_CONTEXT=../vos-front
