# Copiar → cp .env.dev.example .env.dev
# Servidor dev/staging: VOS_ENV=dev npm run start:prod
# Migraciones: npm run db:migrate:dev

# --- Base de datos (Neon / RDS) ---
DATABASE_URL="postgresql://USER:PASS@ep-xxx.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL=

# --- Auth (openssl rand -base64 48) ---
JWT_SECRET=local-docker-vos-ai-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Cuenta admin (seed) — mismos valores que en local
SEED_ADMIN_EMAIL=admin@vos.ai
SEED_ADMIN_PASSWORD=VosAi2026!
SEED_ADMIN_NAME=Administrador VOS AI
SEED_ARANDANO_EMAIL=owner@arandano.com
SEED_ARANDANO_PASSWORD=Arandano2026!
SEED_ARANDANO_NAME=Propietario Arándano
ADMIN_NOTIFY_EMAIL=admin@vos.ai

PORT=3000
LISTEN_HOST=0.0.0.0
NODE_ENV=production

# Origen HTTPS del front desplegado
CORS_ORIGIN=https://dev.tudominio.com

SHOP_FRONT_URL=https://dev.tudominio.com
SHOP_NEQUI_PHONE=
SHOP_BREB_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_API_BASE=https://production.wompi.co/v1

WHATSAPP_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_CONTENT_SID=
TWILIO_WHATSAPP_INTERNAL_TO=
WHATSAPP_INTERNAL_GROUP=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
REDIS_URL=redis://redis:6379

GOOGLE_CLIENT_ID=

RUN_MIGRATIONS_ON_START=true
