# Copiar → cp .env.local.example .env.local
# ⚠️ Si ya tenés .env.local con DATABASE_URL de Neon, NO lo sobrescribas.
# Local: npm run start:dev  |  Migraciones: npm run db:migrate

# --- Base de datos (Neon administrada o Postgres local en :5433) ---
# Pegá tu connection string del panel Neon (branch production):
DATABASE_URL="postgresql://USER:PASS@ep-xxx.neon.tech/neondb?sslmode=require"
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/vos"

# --- Auth ---
JWT_SECRET=local-docker-vos-ai-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Cuenta admin (seed) — mismos valores en servidor
SEED_ADMIN_EMAIL=admin@vos.ai
SEED_ADMIN_PASSWORD=VosAi2026!
SEED_ADMIN_NAME=Administrador VOS AI
SEED_ARANDANO_EMAIL=owner@arandano.com
SEED_ARANDANO_PASSWORD=Arandano2026!
SEED_ARANDANO_NAME=Propietario Arándano
ADMIN_NOTIFY_EMAIL=admin@vos.ai

PORT=3000
LISTEN_HOST=0.0.0.0
NODE_ENV=development

# Orígenes del front en local (Vite :5173)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Tienda / WhatsApp / pagos
SHOP_FRONT_URL=http://localhost:5173
SHOP_NEQUI_PHONE=
SHOP_BREB_KEY=@ARANDANOCAFE
WOMPI_PRIVATE_KEY=
WOMPI_API_BASE=https://production.wompi.co/v1

WHATSAPP_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_CONTENT_SID=
TWILIO_WHATSAPP_INTERNAL_TO=
WHATSAPP_INTERNAL_GROUP=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=
REDIS_URL=redis://localhost:6379

# Google Sign-In (mismo Client ID que VITE_GOOGLE_CLIENT_ID en el front)
GOOGLE_CLIENT_ID=
