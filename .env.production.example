# Copiar en el servidor → cp .env.production.example .env && nano .env
# Local NO uses este archivo; usá .env.local.example → .env.local
#
# PM2: pm2 restart vos-api --update-env
# ⚠️ En producción NO dejes .env.local (pisa CORS, PORT y NODE_ENV).

# --- Base de datos (Neon) ---
DATABASE_URL="postgresql://USER:PASS@ep-xxx.neon.tech/neondb?sslmode=require"

# --- Auth (openssl rand -base64 48) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

NODE_ENV=production
# Puerto 3001 si :3000 lo usa otra app (Next.js arandano en el VPS Arándano)
PORT=3001
LISTEN_HOST=0.0.0.0
RUN_MIGRATIONS_ON_START=false

# Orígenes del front — EXACTOS (protocolo + host + puerto, sin / final).
# Con Nginx + HTTPS: https://vos-ai.arandano.shop
# Pruebas por IP: http://51.222.24.228:5174
CORS_ORIGIN=https://vos-ai.arandano.shop,http://51.222.24.228:5174

HTTP_BODY_LIMIT=12mb

# Asistente IA + bot landing
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_COMPANY_ID=seed-arandano-cafe-bar
TELEGRAM_BOT_ENABLED=false

# Tienda / pagos
SHOP_FRONT_URL=https://vos-ai.arandano.shop
SHOP_NEQUI_PHONE=
SHOP_BREB_KEY=@ARANDANOCAFE
WOMPI_PRIVATE_KEY=
WOMPI_API_BASE=https://production.wompi.co/v1

# Google Sign-In (mismo Client ID que VITE_GOOGLE_CLIENT_ID en el front)
GOOGLE_CLIENT_ID=

# --- Solo Docker compose (no PM2) ---
# API_SERVER_PORT=3000
# FRONT_SERVER_PORT=8080
# FRONTEND_BUILD_CONTEXT=../vos-front
