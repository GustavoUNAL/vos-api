# Copiar → cp .env.production.example .env
# VPS: docker compose -f docker-compose.vps.yml --profile full up -d --build

# --- Base de datos (Neon / RDS) ---
DATABASE_URL="postgresql://USER:PASS@ep-xxx.neon.tech/neondb?sslmode=require"

# --- Auth (openssl rand -base64 48) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

NODE_ENV=production
PORT=3000
LISTEN_HOST=0.0.0.0
RUN_MIGRATIONS_ON_START=true

# URL(s) del front, separadas por coma (sin barra final)
CORS_ORIGIN=https://app.tudominio.com

# Body parser — comprobantes POS en base64
HTTP_BODY_LIMIT=12mb

# Asistente de negocio + bot landing
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o

# Telegram (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_BOT_ENABLED=false

# --- Build del front (docker-compose args) ---
# URL del API vista desde el navegador (mismo host:puerto o subdominio api.)
VITE_API_URL=http://TU_IP:3000
VITE_APP_URL=http://TU_IP:8080
VITE_LANDING_URL=http://TU_IP:8080/#/
VITE_SHOP_FRONT_URL=http://TU_IP:8080
VITE_SHOP_URL=http://TU_IP:8080/#/tienda/arandano
VITE_LANDING_WHATSAPP_URL=https://wa.me/57XXXXXXXXXX
VITE_PLATFORM_MODE=true
VITE_SHOP_SLUG=arandano
VITE_BRAND_NAME=VOS AI
VITE_BRAND_TAGLINE=Sistema operativo inteligente para empresas.
FRONTEND_BUILD_CONTEXT=../vos-front

# Puertos publicados en el host
API_SERVER_PORT=3000
FRONT_SERVER_PORT=8080
